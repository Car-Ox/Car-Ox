{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hook": "echo '[Claude Code] 提示：请更新今日开发日志 → .devlogs/$(date +%Y-%m-%d).md'"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python -m pytest *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)"
    ]
  },
  "env": {
    "LIVE2GIF_MAX_WORKERS": "4",
    "FFMPEG_PATH": ""
  }
}
